{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      ".git/**": "deny"
      "esphome-espnow-tree-ha/components/**/*": "deny"
    },
    "grep": "allow",
    "glob": "allow",
    "edit": "allow",
    "bash": {
      "sudo *": "ask",
      "rm -rf /": "deny",
      "*": "allow"
    }
  }
}