FROM python:3.13-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends nodejs npm && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY esphome-espnow-tree-ha/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY esphome-espnow-tree-ha/ui/ ./ui/
WORKDIR /app/ui
RUN npm ci && npx vite build

WORKDIR /app
COPY esphome-espnow-tree-ha/app/ ./app/

ENV ESPNOW_TREE_DATA_DIR=/data
ENV PYTHONUNBUFFERED=1

EXPOSE 8099

CMD ["uvicorn", "app.main:create_app", "--factory", "--host", "0.0.0.0", "--port", "8099"]