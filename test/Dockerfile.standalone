FROM python:3.13-slim

RUN --mount=type=cache,target=/var/lib/apt/lists apt-get update && \
    apt-get install -y --no-install-recommends nodejs npm

WORKDIR /app

COPY requirements.txt .
RUN --mount=type=cache,target=/root/.cache/pip pip install -r requirements.txt

COPY ui/ ./ui/
WORKDIR /app/ui
RUN --mount=type=cache,target=/app/ui/node_modules npm ci && npx vite build

WORKDIR /app
COPY app/ ./app/

ENV ESP_TREE_DATA_DIR=/data
ENV PYTHONUNBUFFERED=1

EXPOSE 8099

CMD ["uvicorn", "app.main:create_app", "--factory", "--host", "0.0.0.0", "--port", "8099"]